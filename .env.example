# Supabase — copy to .env.local and fill in your project's values.
# Dashboard → Project Settings → Data API / API Keys.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Prefer the new publishable key (sb_publishable_...). The legacy anon key is
# read as a fallback for older projects.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Base URL of the deployed site, used to build the OAuth redirect target.
# Optional in local dev (falls back to the request origin); set in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
